# Backend URL for the API proxy (used in production on Vercel).
# Set one of these in Vercel → Project → Settings → Environment Variables.
# Use your Render backend URL, e.g. https://your-app.onrender.com (no trailing slash).
BACKEND_URL=
# Or if you need the URL in the browser as well:
# NEXT_PUBLIC_API_URL=

# Optional: override GHL form on /l/ghl (default is set in app/l/ghl/page.tsx).
# NEXT_PUBLIC_GHL_FORM_IFRAME_URL=https://link.apisystem.tech/widget/form/YOUR_ID

# Landing pages → “Publish on your website & DNS” helpers (shown in-app to staff).
# CNAME destination visitors should ultimately hit (omit https://), e.g. landing.yoursaas.net
# NEXT_PUBLIC_LANDING_DNS_CNAME_TARGET=landing.yoursaas.net
# Optional: template for the final public funnel URL once routing exists ({slug}, {id}, {subdomain} replaced).
# NEXT_PUBLIC_LANDING_PUBLIC_URL_TEMPLATE=https://go.yoursite.com/l/{slug}
